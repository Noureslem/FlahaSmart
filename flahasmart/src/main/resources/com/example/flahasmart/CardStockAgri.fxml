<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<AnchorPane prefHeight="235.0" prefWidth="188.0" stylesheets="@css/style.css" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.flahasmart.controllers.CardStockAchriController">

    <VBox prefHeight="194.0" prefWidth="188.0" spacing="8" styleClass="stock-card" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0.0">
        <padding>
            <Insets bottom="12" left="12" right="12" top="12" />
        </padding>

        <Label fx:id="typeLabel" styleClass="title" text="Type" />
        <Label fx:id="varieteLabel" styleClass="muted" text="Variété" />

        <HBox spacing="8">
            <Label styleClass="muted" text="Début :" />
            <Label fx:id="dateLabel" text="2026-02-17" />
        </HBox>

        <HBox spacing="8">
            <Label styleClass="muted" text="Statut :" />
            <Label fx:id="statutLabel" styleClass="badge" text="en cours" />
        </HBox>

        <HBox alignment="CENTER" spacing="5" prefHeight="30">
            <Button fx:id="consumptionBtn" onAction="#openConsumption" styleClass="btn-consumption" prefWidth="30">
                <graphic><FontIcon iconColor="white" iconLiteral="fas-chart-line" iconSize="14"/></graphic>
            </Button>
            <Button fx:id="qrBtn" onAction="#openQRCode" styleClass="btn-consumption" prefWidth="30">
                <graphic><FontIcon iconColor="white" iconLiteral="fas-qrcode" iconSize="14"/></graphic>
            </Button>
            <Button fx:id="editBtn" onAction="#editItem" styleClass="btn-consumption" prefWidth="30" style="-fx-background-color: green;">
                <graphic><FontIcon iconColor="white" iconLiteral="fas-edit" iconSize="14"/></graphic>
            </Button>
            <Button fx:id="deleteBtn" onAction="#deleteItem" styleClass="btn-consumption" prefWidth="30" style="-fx-background-color: red;">
                <graphic><FontIcon iconColor="white" iconLiteral="fas-trash" iconSize="14"/></graphic>
            </Button>
        </HBox>
    </VBox>

</AnchorPane>
