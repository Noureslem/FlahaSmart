<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400" prefWidth="500" spacing="10" styleClass="search-card" stylesheets="@css/style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/23.0.1" fx:controller="com.example.flahasmart.controllers.ApiConsommationDetailController">
    <Label fx:id="productNameLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;" styleClass="badge-green" />
    <ProgressIndicator fx:id="loadingIndicator" visible="false" />
    <TextArea fx:id="detailsArea" editable="false" styleClass="toast-success" wrapText="true" VBox.vgrow="ALWAYS" />
</VBox>
