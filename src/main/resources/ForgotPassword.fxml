<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<BorderPane prefHeight="720" prefWidth="1200"
            style="-fx-background-color: #f8fafc;"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.Auth.ForgotPassword">

    <!-- PANNEAU GAUCHE -->
    <left>
        <AnchorPane prefWidth="480"
                    style="-fx-background-color: linear-gradient(to bottom right, #1e293b, #334155, #1e293b);">

            <Circle radius="200" layoutX="480" layoutY="100"
                    style="-fx-fill: rgba(255,255,255,0.03);" />
            <Circle radius="150" layoutX="-40" layoutY="650"
                    style="-fx-fill: rgba(255,255,255,0.04);" />

            <VBox layoutX="55" layoutY="100" prefWidth="370" spacing="30">

                <HBox alignment="CENTER_LEFT" spacing="12">
                    <Label text="🌿" style="-fx-font-size: 30px;" />
                    <Label text="FlahaSmart"
                           style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Georgia';" />
                </HBox>

                <VBox spacing="6">
                    <Label text="Mot de passe"
                           style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-family: 'Georgia';" />
                    <Label text="oublié ?"
                           style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: #6ee7b7; -fx-font-family: 'Georgia';" />
                    <Label text="Pas de panique !"
                           style="-fx-font-size: 34px; -fx-font-weight: bold; -fx-text-fill: rgba(255,255,255,0.85); -fx-font-family: 'Georgia';" />
                </VBox>

                <Rectangle width="55" height="4"
                           style="-fx-fill: #6ee7b7; -fx-arc-width: 4; -fx-arc-height: 4;" />

                <Label text="Suivez les 3 étapes simples pour récupérer l'accès à votre compte FlahaSmart."
                       wrapText="true" prefWidth="350"
                       style="-fx-text-fill: rgba(255,255,255,0.65); -fx-font-size: 14px; -fx-line-spacing: 3;" />

                <!-- Étapes visuelles -->
                <VBox spacing="20" style="-fx-padding: 10 0 0 0;">
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="1"
                               style="-fx-background-color: #047857; -fx-text-fill: white; -fx-font-weight: bold;
                                      -fx-min-width: 32; -fx-min-height: 32; -fx-background-radius: 50;
                                      -fx-alignment: center; -fx-font-size: 14px;" />
                        <VBox spacing="2">
                            <Label text="Entrez votre email"
                                   style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;" />
                            <Label text="Celui associé à votre compte"
                                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 12px;" />
                        </VBox>
                    </HBox>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="2"
                               style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-weight: bold;
                                      -fx-min-width: 32; -fx-min-height: 32; -fx-background-radius: 50;
                                      -fx-alignment: center; -fx-font-size: 14px;" />
                        <VBox spacing="2">
                            <Label text="Vérifiez votre email"
                                   style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-weight: bold; -fx-font-size: 14px;" />
                            <Label text="Saisissez le code à 6 chiffres reçu"
                                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 12px;" />
                        </VBox>
                    </HBox>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <Label text="3"
                               style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-font-weight: bold;
                                      -fx-min-width: 32; -fx-min-height: 32; -fx-background-radius: 50;
                                      -fx-alignment: center; -fx-font-size: 14px;" />
                        <VBox spacing="2">
                            <Label text="Nouveau mot de passe"
                                   style="-fx-text-fill: rgba(255,255,255,0.75); -fx-font-weight: bold; -fx-font-size: 14px;" />
                            <Label text="Choisissez un mot de passe sécurisé"
                                   style="-fx-text-fill: rgba(255,255,255,0.5); -fx-font-size: 12px;" />
                        </VBox>
                    </HBox>
                </VBox>

            </VBox>
        </AnchorPane>
    </left>

    <!-- PANNEAU DROIT -->
    <center>
        <AnchorPane style="-fx-background-color: #f8fafc;">
            <VBox alignment="CENTER" spacing="0"
                  AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
                  AnchorPane.leftAnchor="60" AnchorPane.rightAnchor="60">

                <VBox maxWidth="420" spacing="24">

                    <!-- Titre -->
                    <VBox spacing="5">
                        <Label text="Réinitialisation"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1e293b; -fx-font-family: 'Georgia';" />
                        <Label text="du mot de passe"
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" />
                    </VBox>

                    <!-- Messages -->
                    <Text fx:id="errorMessage" visible="false" wrappingWidth="400"
                          style="-fx-fill: #ef4444; -fx-font-size: 13px;" />
                    <Text fx:id="successMessage" visible="false" wrappingWidth="400"
                          style="-fx-fill: #047857; -fx-font-size: 13px; -fx-font-weight: bold;" />

                    <!-- ══ ÉTAPE 1 : Email ══ -->
                    <VBox fx:id="stepEmail" spacing="16">
                        <Label text="Étape 1 — Votre adresse email"
                               style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <VBox spacing="6">
                            <Label text="EMAIL"
                                   style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;" />
                            <TextField fx:id="emailField" promptText="exemple@email.com"
                                       style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-prompt-text-fill: #cbd5e1;
                                              -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;
                                              -fx-border-width: 1.5; -fx-padding: 13 15; -fx-font-size: 14px;" />
                        </VBox>
                        <Button fx:id="sendCodeButton" text="ENVOYER LE CODE"
                                maxWidth="999" prefHeight="46"
                                onAction="#handleSendCode"
                                style="-fx-background-color: linear-gradient(to right, #047857, #065f46); -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10;
                                       -fx-cursor: hand; -fx-border-width: 0;" />
                    </VBox>

                    <!-- ══ ÉTAPE 2 : Code ══ -->
                    <VBox fx:id="stepCode" spacing="16" visible="false" managed="false">
                        <Label text="Étape 2 — Code de vérification"
                               style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <Label text="Vérifiez votre boîte email et entrez le code à 6 chiffres reçu."
                               wrapText="true"
                               style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;" />
                        <VBox spacing="6">
                            <Label text="CODE À 6 CHIFFRES"
                                   style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;" />
                            <TextField fx:id="tokenField" promptText="000000"
                                       style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-prompt-text-fill: #cbd5e1;
                                              -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;
                                              -fx-border-width: 1.5; -fx-padding: 13 15; -fx-font-size: 22px;
                                              -fx-alignment: center; -fx-font-weight: bold; -fx-letter-spacing: 6;" />
                        </VBox>
                        <Button fx:id="verifyCodeButton" text="VÉRIFIER LE CODE"
                                maxWidth="999" prefHeight="46"
                                onAction="#handleVerifyCode"
                                style="-fx-background-color: linear-gradient(to right, #047857, #065f46); -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10;
                                       -fx-cursor: hand; -fx-border-width: 0;" />
                    </VBox>

                    <!-- ══ ÉTAPE 3 : Nouveau mot de passe ══ -->
                    <VBox fx:id="stepPassword" spacing="16" visible="false" managed="false">
                        <Label text="Étape 3 — Nouveau mot de passe"
                               style="-fx-text-fill: #475569; -fx-font-size: 13px; -fx-font-weight: bold;" />
                        <VBox spacing="6">
                            <Label text="NOUVEAU MOT DE PASSE"
                                   style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;" />
                            <PasswordField fx:id="newPasswordField" promptText="Minimum 6 caractères"
                                           style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-prompt-text-fill: #cbd5e1;
                                                  -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;
                                                  -fx-border-width: 1.5; -fx-padding: 13 15; -fx-font-size: 14px;" />
                        </VBox>
                        <VBox spacing="6">
                            <Label text="CONFIRMER"
                                   style="-fx-text-fill: #64748b; -fx-font-size: 11px; -fx-font-weight: bold;" />
                            <PasswordField fx:id="confirmNewPasswordField" promptText="Confirmez"
                                           style="-fx-background-color: white; -fx-text-fill: #1e293b; -fx-prompt-text-fill: #cbd5e1;
                                                  -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;
                                                  -fx-border-width: 1.5; -fx-padding: 13 15; -fx-font-size: 14px;" />
                        </VBox>
                        <Button fx:id="resetButton" text="RÉINITIALISER MON MOT DE PASSE"
                                maxWidth="999" prefHeight="46"
                                onAction="#handleResetPassword"
                                style="-fx-background-color: linear-gradient(to right, #047857, #065f46); -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 10;
                                       -fx-cursor: hand; -fx-border-width: 0;" />
                    </VBox>

                    <!-- Retour login -->
                    <HBox alignment="CENTER">
                        <Button fx:id="backToLoginButton" text="← Retour à la connexion"
                                onAction="#handleBackToLogin"
                                style="-fx-background-color: transparent; -fx-text-fill: #64748b;
                                       -fx-font-size: 13px; -fx-cursor: hand; -fx-border-width: 0;" />
                    </HBox>

                </VBox>
            </VBox>
        </AnchorPane>
    </center>

</BorderPane>
